# Network authentication
INTERLINK_RPC_URL=https://evm-rpc.test-net.interlinklabs.ai/v1/rpc
INTERLINK_CHAIN_ID=19042026
INTERLINK_TOKEN=
PRIVATE_KEY=

# Constructor arguments
SETTLEMENT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
ADMIN_ADDRESS=0x0000000000000000000000000000000000000000
# Leave empty for production: ADMIN_ADDRESS must be a deployed multisig.
# The exact value below is accepted only for a consciously reviewed testnet EOA.
ALLOW_EOA_ADMIN=

# Pin the reviewed settlement-token implementation and metadata.
SETTLEMENT_TOKEN_CODEHASH=0x
SETTLEMENT_TOKEN_DECIMALS=18

# Deployment safety controls
DEPLOYMENT_CONFIRMATION=REVIEWED_INTERPREDICT_V2_DEPLOYMENT
DEPLOY_CONFIRMATIONS=2
MIN_DEPLOYER_BALANCE_WEI=0
MAX_INTERPREDICT_RUNTIME_BYTES=23750
MAX_READER_RUNTIME_BYTES=4096

# Optional comma-separated role/member bootstrap. This is only possible when
# PRIVATE_KEY controls ADMIN_ADDRESS; otherwise leave these empty and execute
# the documented multisig transactions after deployment.
TEAM_MARKET_ACCOUNTS=
DEC_MANAGER_ACCOUNTS=
DEC_MEMBERS=

# Used by `npm run verify:deployment`.
INTERPREDICT_READER_ADDRESS=
INTERPREDICT_ADDRESS=
DEPLOYMENT_MANIFEST=
