{
  "name": "interpredict-deploy",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test mocha",
    "test:fuzz": "hardhat test mocha --grep \"property|fuzz|invariant\"",
    "test:tooling": "node --test scripts/artifact-tools.test.mjs",
    "abi:export": "node scripts/artifact-tools.mjs abi export",
    "abi:check": "node scripts/artifact-tools.mjs abi check",
    "size:check": "node scripts/artifact-tools.mjs size check",
    "storage:export": "node scripts/artifact-tools.mjs storage export",
    "storage:check": "node scripts/artifact-tools.mjs storage check",
    "verify:deployment": "hardhat run scripts/verify-deployment.js --network interlink_testnet",
    "deploy:interlink": "hardhat run scripts/deploy.js --network interlink_testnet",
    "validate": "npm run compile && npm test && npm run test:tooling && npm run abi:check && npm run size:check && npm run storage:check"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^3.0.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.14",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.11",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.7",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^22.20.1",
    "chai": "^6.2.2",
    "ethers": "^6.17.0",
    "fast-check": "^4.9.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.9.1",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
