# Browser-visible deployment metadata. These values are public.
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SETTLEMENT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SETTLEMENT_TOKEN_SYMBOL=tITL
# Optional but recommended: first block queried for protocol history events.
NEXT_PUBLIC_CONTRACT_DEPLOYMENT_BLOCK=

# Interlink authenticated RPC configuration used by server-side API routes.
INTERLINK_RPC_URL=https://evm-rpc.test-net.interlinklabs.ai/v1/rpc
INTERLINK_CHAIN_ID=19042026

# Dedicated, minimally funded service wallet. Never use the protocol admin key.
SERVICE_WALLET_PRIVATE_KEY=

# Vercel Cron sends this value as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# Bounded API/keeper work controls.
MARKETS_PAGE_SIZE=24
MARKETS_MAX_PAGE_SIZE=50
MARKETS_RPC_CONCURRENCY=6
MARKETS_RPC_TIMEOUT_MS=12000
KEEPER_BATCH_SIZE=25
KEEPER_MAX_BATCH_SIZE=50
KEEPER_MAX_TRANSACTIONS=10
KEEPER_TIME_BUDGET_MS=45000
KEEPER_CONFIRMATIONS=1
KEEPER_SETTLEMENTS_PER_MARKET=5
KEEPER_SETTLEMENT_SCAN_SIZE=25
KEEPER_RPC_TIMEOUT_MS=15000
