{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "tsx --test \"lib/**/*.test.ts\"",
    "protocol:compile": "npm --prefix interpredict-deploy run compile",
    "protocol:test": "npm --prefix interpredict-deploy test",
    "protocol:abi:check": "npm --prefix interpredict-deploy run abi:check",
    "protocol:size:check": "npm --prefix interpredict-deploy run size:check",
    "protocol:storage:check": "npm --prefix interpredict-deploy run storage:check",
    "validate:app": "npm run lint && npm run typecheck && npm run test:unit && npm run build",
    "validate:protocol": "npm --prefix interpredict-deploy run validate",
    "validate": "npm run validate:app && npm run validate:protocol"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ethers": "^6.17.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.5.16",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "5.7.3"
  }
}
